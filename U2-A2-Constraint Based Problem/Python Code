# ============================================================
from collections import deque

# 5x5 Grid
grid = [
    ['S', '.', '.', '#', '.'],
    ['.', '#', '.', '#', '.'],
    ['.', '#', '.', '.', '.'],
    ['.', '.', '#', '#', '.'],
    ['#', '.', '.', 'G', '.']
]

rows = 5
cols = 5

# Find Start and Goal positions
for i in range(rows):
    for j in range(cols):
        if grid[i][j] == 'S':
            start = (i, j)
        elif grid[i][j] == 'G':
            goal = (i, j)

# Possible movements
directions = [
    (-1, 0),  # Up
    (1, 0),   # Down
    (0, -1),  # Left
    (0, 1)    # Right
]

# BFS Function
def bfs(start, goal):

    queue = deque()
    queue.append((start, [start]))

    visited = set()
    visited.add(start)

    while queue:

        current, path = queue.popleft()

        print("Current Node:", current)
        print("Queue:", list(queue))

        if current == goal:
            return path

        for dx, dy in directions:

            x = current[0] + dx
            y = current[1] + dy

            if 0 <= x < rows and 0 <= y < cols:

                if grid[x][y] != '#' and (x, y) not in visited:

                    visited.add((x, y))
                    queue.append(((x, y), path + [(x, y)]))

    return None


# Driver Code
path = bfs(start, goal)

if path:

    print("\nShortest Path:")
    print(path)

    print("\nTotal Cost =", len(path) - 1)

else:
    print("No Path Found")



