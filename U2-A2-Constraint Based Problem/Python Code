import heapq

# 5x5 Grid
grid = [
    ['S', '.', '.', '#', '.'],
    ['.', 'R', '.', '#', '.'],
    ['.', '#', '.', '.', '.'],
    ['.', '.', 'R', '#', '.'],
    ['#', '.', '.', 'G', '.']
]

rows = 5
cols = 5

# Find Start and Goal
for i in range(rows):
    for j in range(cols):
        if grid[i][j] == 'S':
            start = (i, j)
        elif grid[i][j] == 'G':
            goal = (i, j)

# Possible moves
directions = [
    (-1, 0),  # Up
    (1, 0),   # Down
    (0, -1),  # Left
    (0, 1)    # Right
]

# Uniform Cost Search Function
def uniform_cost_search(start, goal):

    # Priority Queue
    pq = []

    # (cost, current_position, path)
    heapq.heappush(pq, (0, start, [start]))

    visited = {}

    while pq:

        cost, current, path = heapq.heappop(pq)

        print("Current Node:", current)
        print("Current Cost:", cost)

        if current == goal:
            return path, cost

        if current in visited and visited[current] <= cost:
            continue

        visited[current] = cost

        for dx, dy in directions:

            x = current[0] + dx
            y = current[1] + dy

            if 0 <= x < rows and 0 <= y < cols:

                if grid[x][y] != '#':

                    # Normal move cost
                    new_cost = cost + 1

                    # Extra cost for risky zone
                    if grid[x][y] == 'R':
                        new_cost += 2

                    heapq.heappush(
                        pq,
                        (new_cost, (x, y), path + [(x, y)])
                    )

    return None, None


# Driver Code
path, cost = uniform_cost_search(start, goal)

if path:
    print("\nMinimum Cost Path:")
    print(path)
    print("Total Cost =", cost)
else:
    print("No Path Found")



