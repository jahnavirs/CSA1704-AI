# ============================================================
# QUESTION 1
# Hospital Doctor Scheduling using Backtracking Search
# ============================================================
# List of doctors
doctors = ["D1", "D2", "D3"]

# List of available shifts
shifts = ["Morning", "Afternoon", "Night"]

# Dictionary to store final assignment
assignment = {}

# ---------------------------------------
# Function to check whether assignment is valid
# ---------------------------------------

def is_safe(doctor, shift):

    # Constraint 1:
    # One shift should not be assigned twice
    if shift in assignment.values():
        return False

    # Constraint 2:
    # D1 cannot work Night shift
    if doctor == "D1" and shift == "Night":
        return False

    # Constraint 3:
    # D2 cannot work Morning shift
    if doctor == "D2" and shift == "Morning":
        return False

    return True


# ---------------------------------------
# Backtracking Function
# ---------------------------------------

def backtrack(index):

    # Base condition
    if index == len(doctors):
        return True

    # Current doctor
    doctor = doctors[index]

    # Try every shift
    for shift in shifts:

        print(f"Trying {doctor} -> {shift}")

        # Check constraints
        if is_safe(doctor, shift):

            # Assign shift
            assignment[doctor] = shift

            print("Assigned:", assignment)

            # Recursive call
            if backtrack(index + 1):
                return True

            # Backtracking
            print("Backtracking from", doctor)

            del assignment[doctor]

    return False


# ---------------------------------------
# Driver Code
# ---------------------------------------

if backtrack(0):

    print("\nValid Schedule")

    for doctor, shift in assignment.items():
        print(doctor, "->", shift)

else:
    print("No valid schedule found.")





