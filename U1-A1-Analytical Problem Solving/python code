import heapq

# Graph representing warehouses and travel costs
graph = {
    'A': [('B', 2), ('C', 4)],
    'B': [('D', 7), ('E', 3)],
    'C': [('F', 5)],
    'D': [('G', 1)],
    'E': [('G', 6)],
    'F': [('G', 2)],
    'G': []
}

# Uniform Cost Search Function
def uniform_cost_search(graph, start, goal):

    # Priority Queue (Cost, Current Node, Path)
    queue = [(0, start, [start])]

    visited = set()

    while queue:

        cost, node, path = heapq.heappop(queue)

        if node in visited:
            continue

        visited.add(node)

        if node == goal:
            return cost, path

        for neighbor, edge_cost in graph[node]:
            if neighbor not in visited:
                heapq.heappush(queue,
                               (cost + edge_cost,
                                neighbor,
                                path + [neighbor]))

    return None


# User Input
start = input("Enter Starting Warehouse: ").upper()
goal = input("Enter Destination Warehouse: ").upper()

result = uniform_cost_search(graph, start, goal)

if result:
    total_cost, shortest_path = result
    print("\nOptimal Path :", " -> ".join(shortest_path))
    print("Minimum Cost :", total_cost)
else:
    print("No path found.")
