from collections import deque

print("=" * 60)
print("QUESTION 1 - WATER JUG PROBLEM")
print("=" * 60)

def water_jug():
    visited = set()
    queue = deque([((0, 0), [])])

    while queue:
        (a, b), path = queue.popleft()

        if a == 2:
            print("\nGoal Reached!\n")
            for state in path + [(a, b)]:
                print(state)
            return

        if (a, b) in visited:
            continue

        visited.add((a, b))

        next_states = [

            (4, b),                     # Fill 4L

            (a, 3),                     # Fill 3L

            (0, b),                     # Empty 4L

            (a, 0),                     # Empty 3L

            (a - min(a, 3 - b), b + min(a, 3 - b)),   # 4 -> 3

            (a + min(b, 4 - a), b - min(b, 4 - a))    # 3 -> 4

        ]

        for state in next_states:

            if state not in visited:
                queue.append((state, path + [(a, b)]))

water_jug()

print("\n")


