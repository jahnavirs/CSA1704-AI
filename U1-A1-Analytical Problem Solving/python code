import heapq

graph = {

'S':[('A',1),('G',12)],

'A':[('B',3),('C',1)],

'B':[('D',3)],

'C':[('D',1),('G',2)],

'D':[('G',3)],

'G':[]

}


def ucs(start, goal):

    pq = [(0, start, [start])]

    visited = set()

    while pq:

        cost, node, path = heapq.heappop(pq)

        if node == goal:
            return cost, path

        if node in visited:
            continue

        visited.add(node)

        for neighbour, weight in graph[node]:

            if neighbour not in visited:

                heapq.heappush(

                    pq,

                    (cost + weight, neighbour, path + [neighbour])

                )

cost, path = ucs('S', 'G')

print("\nLeast Cost Path")

print(" -> ".join(path))

print("Minimum Cost =", cost)

