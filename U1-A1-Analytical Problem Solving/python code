# QUESTION 1 - WATER JUG PROBLEM USING BFS
# ==========================================================
# Water Jug Problem

jug1_capacity = 4
jug2_capacity = 3

jug1 = 0
jug2 = 0

goal = 2

while jug1 != goal:

    # Fill Jug 2
    if jug2 == 0:
        jug2 = jug2_capacity
        print("Fill Jug2:", (jug1, jug2))

    # Pour Jug2 into Jug1
    transfer = min(jug2, jug1_capacity - jug1)
    jug1 += transfer
    jug2 -= transfer
    print("Pour Jug2 -> Jug1:", (jug1, jug2))

    # Empty Jug1 if full
    if jug1 == jug1_capacity:
        jug1 = 0
        print("Empty Jug1:", (jug1, jug2))

print("\nGoal Achieved!")
print("Final State:", (jug1, jug2))

           


